// force vercel rebuild
import pkg from '@supabase/supabase-js';
const { createClient } = pkg;

const supabase = createClient(
  process.env.SUPABASE_URL,
  process.env.SUPABASE_SERVICE_ROLE_KEY
);

export default async function handler(req, res) {
  if (req.method !== "POST") {
    return res.status(405).json({ error: "Method not allowed" });
  }

  try {
    const { description, amount, type } = req.body;

    // Load current funds
    const { data: funds, error: loadError } = await supabase
      .from("funds")
      .select("*")
      .eq("id", 1)
      .single();

    if (loadError) throw loadError;

    // Determine delta (+ or -)
    const delta = type === "income" ? amount : -amount;

    // Determine which balance to update
    let newClean = funds.clean;
    let newDirty = funds.dirty;

    if (description.toLowerCase().includes("dirty")) {
      newDirty = funds.dirty + delta;
    } else {
      newClean = funds.clean + delta;
    }

    // Update funds
    const { error: updateError } = await supabase
      .from("funds")
      .update({ clean: newClean, dirty: newDirty })
      .eq("id", 1);

    if (updateError) throw updateError;

    // Insert transaction
    const { error: txError } = await supabase
      .from("transactions")
      .insert({
        type,
        direction: type,
        delta,
        amount,
        balance_after: description.toLowerCase().includes("dirty") ? newDirty : newClean,
        description,
        created_at: new Date().toISOString()
      });

    if (txError) throw txError;

    res.status(200).json({
      clean: newClean,
      dirty: newDirty
    });

  } catch (err) {
    console.error("addTransaction error:", err);
    res.status(500).json({ error: "Failed to add transaction" });
  }
}
